# BharatFinanceAI Backend - Environment Variables
# Copy this file to .env and adjust as needed.
# Never commit .env to version control.

# Gemini API (required for user-specific recommendations)
GEMINI_API_KEY=

# Optional: Gemini model override
# GEMINI_MODEL_NAME=models/gemini-1.5-flash

# CORS: Comma-separated list of allowed frontend origins
# Example: http://localhost:5173,https://myapp.com
CORS_ORIGINS=

# Optional: Override default API/base URLs (public endpoints, no keys)
# MF_API_BASE_URL should include /mf path (e.g. https://api.mfapi.in/mf)
# MF_API_BASE_URL=https://api.mfapi.in/mf
# NSE_CSV_URL=https://archives.nseindia.com/content/equities/EQUITY_L.csv
# INFLATION_API_URL=https://api.worldbank.org/v2/country/IND/indicator/FP.CPI.TOTL.ZG
# GDP_API_URL=https://api.worldbank.org/v2/country/IND/indicator/NY.GDP.MKTP.KD.ZG
# IPO_LIST_URL=https://www.chittorgarh.com/ipo/ipo_list.asp
# IPO_PERFORMANCE_URL=https://www.chittorgarh.com/report/ipo-listing-performance-fy2025/93/
# GMP_URL=https://www.investorgain.com/report/live-ipo-gmp/331/

# Optional: Request timeouts and limits
# IPO_MAX_COUNT=5
# IPO_REQUEST_TIMEOUT=15
# MACRO_REQUEST_TIMEOUT=15
