VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_optional

# BharatFinanceAI Frontend - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Backend API base URL
VITE_API_URL=http://localhost:8000

# Firebase (required for auth and Realtime Database)
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_id:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# News APIs (optional - used when backend news is unavailable)
# NewsAPI: https://newsapi.org
# Finnhub: https://finnhub.io
VITE_NEWSAPI_KEY=your_newsapi_key
VITE_FINNHUB_KEY=your_finnhub_key

# Optional overrides
VITE_CORS_PROXY=https://cors-anywhere.herokuapp.com/
VITE_MFAPI_BASE_URL=https://api.mfapi.in
